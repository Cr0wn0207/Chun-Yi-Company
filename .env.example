# Vercel / production environment variables
# Set these in the Vercel project dashboard (Settings → Environment Variables).

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/chunyi-corp
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=chunyi
ADMIN_PASSWORD=replace-with-a-strong-password
NODE_ENV=production

# Frontend (Vite) — optional on Vercel if API is same origin (/api)
VITE_USE_MOCK_DATA=false
