PORT=5000
NODE_ENV=development

# MongoDB Atlas (무료 M0 클러스터)
# 1. https://cloud.mongodb.com 에서 클러스터 생성
# 2. Database Access → 사용자 생성 (username / password)
# 3. Network Access → IP 허용 (개발: 0.0.0.0/0 또는 현재 IP)
# 4. Connect → Drivers → Node.js → 연결 문자열 복사
# 5. <password>를 실제 비밀번호로 교체 (특수문자는 URL 인코딩, 예: @ → %40)
# 6. 마지막에 DB 이름 추가: /chunyi-corp
# Local MongoDB (use 127.0.0.1 on Windows — localhost may try IPv6 ::1)
MONGODB_URI=mongodb://127.0.0.1:27017/chunyi-corp

# Admin login (set at least JWT_SECRET + ADMIN_USERNAME + password)
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=chunyi
# Development: plain password (do not use in production)
ADMIN_PASSWORD=chunyi
# Production: bcrypt hash from `node scripts/hash-password.js your-password`
# ADMIN_PASSWORD_HASH=
